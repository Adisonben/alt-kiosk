## 📊 Database Schema (SQLite)

```sql
-- Employees synced from cloud
CREATE TABLE IF NOT EXISTS employees (
    id              TEXT PRIMARY KEY,   -- UUID from cloud
    emp_id          TEXT NOT NULL,      -- Display ID (e.g. "ORG001")
    emp_no          INTEGER,
    full_name       TEXT NOT NULL,
    org_id          TEXT NOT NULL,
    updated_at      TEXT NOT NULL,      -- ISO8601 from cloud
    synced_at       TEXT NOT NULL       -- When this row was last synced
);

-- Fingerprint templates linked to employees
CREATE TABLE IF NOT EXISTS fingerprints (
    id              TEXT PRIMARY KEY,   -- UUID from cloud
    employee_id     TEXT NOT NULL,      -- FK → employees.id
    finger_index    INTEGER,
    fingerprint_code TEXT NOT NULL,     -- Base64 encoded template
    updated_at      TEXT NOT NULL,
    synced_at       TEXT NOT NULL,
    FOREIGN KEY (employee_id) REFERENCES employees(id) ON DELETE CASCADE
);

-- Sync tracking metadata
CREATE TABLE IF NOT EXISTS sync_metadata (
    key             TEXT PRIMARY KEY,   -- e.g. "employees_last_sync"
    value           TEXT NOT NULL,      -- ISO8601 timestamp or version
    updated_at      TEXT NOT NULL
);

-- Local scan logs (queued for cloud upload)
CREATE TABLE IF NOT EXISTS scan_logs (
    id              INTEGER PRIMARY KEY AUTOINCREMENT,
    employee_id     TEXT NOT NULL,
    scan_type       TEXT NOT NULL,      -- "fingerprint", "alcohol"
    result          TEXT NOT NULL,      -- "match", "no_match", "pass", "fail"
    value           REAL,              -- alcohol reading (nullable)
    scanned_at      TEXT NOT NULL,      -- ISO8601
    uploaded        INTEGER DEFAULT 0,  -- 0 = pending, 1 = uploaded
    upload_error    TEXT               -- Last error message if upload failed
);

CREATE INDEX IF NOT EXISTS idx_employees_emp_id ON employees(emp_id);
CREATE INDEX IF NOT EXISTS idx_employees_org_id ON employees(org_id);
CREATE INDEX IF NOT EXISTS idx_fingerprints_employee_id ON fingerprints(employee_id);
CREATE INDEX IF NOT EXISTS idx_scan_logs_uploaded ON scan_logs(uploaded);
```

