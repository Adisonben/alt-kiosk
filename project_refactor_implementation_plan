#### New Identification Flow (Python-side)

```python
async def _handle_identify(self, employee_id: str, session_id: str):
    # 1. Lookup employee in local DB
    employee = await self._employee_service.get_by_emp_id(employee_id)
    if not employee:
        push({"type": "identify_result", "success": False, 
              "message": "ไม่พบข้อมูลพนักงาน"})
        return

    # 2. Publish employee found
    push({"type": "identify_result", "success": True,
          "employee": {"name": employee.full_name, "emp_id": employee.emp_id},
          "has_fingerprints": len(employee.fingerprints) > 0})

    # 3. If no fingerprints registered, skip verification
    if not employee.fingerprints:
        push({"type": "verify_result", "success": False, "match": False,
              "message": "ไม่มีข้อมูลลายนิ้วมือในระบบ"})
        return

    # 4. Trigger fingerprint scan + compare against LOCAL templates
    templates = [fp.fingerprint_code for fp in employee.fingerprints]
    match = await self._scan_and_verify(templates)

    # 5. Publish result
    push({"type": "verify_result", "success": True, "match": match,
          "employee": {"name": employee.full_name, "emp_id": employee.emp_id}})

    # 6. Log scan result (async, non-blocking)
    asyncio.create_task(self._scan_log_service.log(
        employee_id=employee.id,
        scan_type="fingerprint",
        result="match" if match else "no_match"
    ))
```

