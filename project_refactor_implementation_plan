        # Upsert all into local DB
        # Update sync_metadata["employees_last_sync"]

    async def _incremental_sync(self):
        """Fetch only employees updated since last sync."""
        last_sync = await self._get_last_sync_time()
        # GET /api/device/employees/{org_id}?updated_since={last_sync}
        # Upsert changed records only

    async def _periodic_worker(self):
        """Run incremental sync every SYNC_INTERVAL_SECONDS."""
        while True:
            await asyncio.sleep(settings.SYNC_INTERVAL_SECONDS)
            try:
                await self._incremental_sync()
            except Exception:
                logger.warning("Sync failed, will retry next cycle")

    async def stop(self):
        """Cancel periodic task."""
