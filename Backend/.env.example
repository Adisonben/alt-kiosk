# ── App ───────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Hardware ──────────────────────────────────────────────────
# ALCOHOL_PORT=/dev/ttyUSB0   # Leave empty for auto-detect
ALCOHOL_BAUDRATE=4800

# ── Local Database ────────────────────────────────────────────
DB_PATH=data/kiosk.db

# ── Cloud API ─────────────────────────────────────────────────
CLOUD_API_URL=https://alcohol.idclever.net/api
CLOUD_API_TOKEN=your-bearer-token-here
CLOUD_ORG_ID=73a8f7ad-32a1-4c9e-b43c-024d3351f8b3
CLOUD_DEVICE_ID=kiosk-001
CLOUD_REQUEST_TIMEOUT=15

# ── Sync ──────────────────────────────────────────────────────
SYNC_INTERVAL_SECONDS=300
SYNC_RETRY_DELAY_SECONDS=30

# ── Scan Log Upload ───────────────────────────────────────────
LOG_UPLOAD_INTERVAL_SECONDS=60
LOG_RETENTION_DAYS=30

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=DEBUG
LOG_DIR=logs
LOG_FILE=alt.log
